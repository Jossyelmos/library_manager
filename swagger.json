{
  "swagger": "2.0",
  "info": {
    "title": "Library Manager API",
    "description": "API for managing authors, books, members, and loans with GitHub OAuth authentication.",
    "version": "1.0.0"
  },
  "host": "library-manager-16n6.onrender.com",
  "basePath": "/",
  "schemes": ["https"],

  "paths": {

    "/auth/github": {
      "get": {
        "tags": ["Auth"],
        "description": "Redirect user to GitHub for authentication",
        "responses": {
          "302": { "description": "Redirect to GitHub" }
        }
      }
    },

    "/auth/github/callback": {
      "get": {
        "tags": ["Auth"],
        "description": "GitHub OAuth callback",
        "responses": {
          "200": { "description": "Authentication successful" },
          "401": { "description": "Authentication failed" }
        }
      }
    },

    "/auth/logout": {
      "get": {
        "tags": ["Auth"],
        "description": "Logout user",
        "responses": {
          "200": { "description": "Logged out successfully" }
        }
      }
    },

    "/authors": {
      "get": {
        "tags": ["Authors"],
        "description": "Get all authors",
        "responses": {
          "200": { "description": "Authors retrieved" },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "tags": ["Authors"],
        "description": "Create a new author",
        "parameters": [
          {
            "in": "body",
            "name": "author",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["firstName", "lastName", "dob"],
              "properties": {
                "firstName": { "type": "string", "example": "Chinua" },
                "lastName": { "type": "string", "example": "Achebe" },
                "nationality": { "type": "string", "example": "Nigerian" },
                "dob": { "type": "string", "example": "1930-11-16" },
                "dod": { "type": "string", "example": "2013-03-21" },
                "biography": { "type": "string" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Author created" },
          "400": { "description": "Invalid input" }
        }
      }
    },

    "/authors/{id}": {
      "get": {
        "tags": ["Authors"],
        "description": "Get author by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Author found" },
          "404": { "description": "Author not found" }
        }
      },
      "put": {
        "tags": ["Authors"],
        "description": "Update author",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "author",
            "schema": {
              "type": "object",
              "properties": {
                "firstName": { "type": "string" },
                "lastName": { "type": "string" },
                "nationality": { "type": "string" },
                "dob": { "type": "string" },
                "dod": { "type": "string" },
                "biography": { "type": "string" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Author updated" },
          "404": { "description": "Author not found" }
        }
      },
      "delete": {
        "tags": ["Authors"],
        "description": "Delete author",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Author deleted" },
          "404": { "description": "Author not found" }
        }
      }
    },

    "/books": {
      "get": {
        "tags": ["Books"],
        "description": "Get all books",
        "responses": {
          "200": { "description": "Books retrieved" }
        }
      },
      "post": {
        "tags": ["Books"],
        "description": "Create a new book",
        "parameters": [
          {
            "in": "body",
            "name": "book",
            "schema": {
              "type": "object",
              "required": ["title", "authorId", "isbn"],
              "properties": {
                "title": { "type": "string" },
                "authorId": { "type": "string" },
                "publishYear": { "type": "string" },
                "isbn": { "type": "string" },
                "genre": { "type": "string" },
                "copiesOwned": { "type": "number" },
                "copiesAvailable": { "type": "number" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Book created" }
        }
      }
    },

    "/books/{id}": {
      "get": {
        "tags": ["Books"],
        "description": "Get book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Book found" }
        }
      },
      "put": {
        "tags": ["Books"],
        "description": "Update book",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "book",
            "schema": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "authorId": { "type": "string" },
                "publishYear": { "type": "string" },
                "isbn": { "type": "string" },
                "genre": { "type": "string" },
                "copiesOwned": { "type": "number" },
                "copiesAvailable": { "type": "number" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Book updated" }
        }
      },
      "delete": {
        "tags": ["Books"],
        "description": "Delete book",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Book deleted" }
        }
      }
    },

    "/members": {
      "get": {
        "tags": ["Members"],
        "description": "Get all members (Protected)",
        "responses": {
          "200": { "description": "Members retrieved successfully" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "tags": ["Members"],
        "description": "Create a new member",
        "parameters": [
          {
            "in": "body",
            "name": "member",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["firstName", "lastName", "email", "password"],
              "properties": {
                "firstName": { "type": "string", "example": "John" },
                "lastName": { "type": "string", "example": "Doe" },
                "phone": { "type": "string", "example": "07012345678" },
                "email": { "type": "string", "example": "john@example.com" },
                "password": { "type": "string", "example": "password123" },
                "status": {
                  "type": "string",
                  "enum": ["active", "inactive"],
                  "example": "active"
                },
                "role": {
                  "type": "string",
                  "enum": ["member", "admin"],
                  "example": "member"
                }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Member created successfully" },
          "400": { "description": "Invalid input" }
        }
      }
    },
    
    "/members/{id}": {
      "get": {
        "tags": ["Members"],
        "description": "Get a member by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Member ID"
          }
        ],
        "responses": {
          "200": { "description": "Member found" },
          "404": { "description": "Member not found" }
        }
      },
      "put": {
        "tags": ["Members"],
        "description": "Update a member (Protected)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "member",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "firstName": { "type": "string" },
                "lastName": { "type": "string" },
                "phone": { "type": "string" },
                "email": { "type": "string" },
                "password": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["active", "inactive"]
                },
                "role": {
                  "type": "string",
                  "enum": ["member", "admin"]
                }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Member updated successfully" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Member not found" }
        }
      },
      "delete": {
        "tags": ["Members"],
        "description": "Delete a member (Protected)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Member deleted successfully" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Member not found" }
        }
      }
    },

    "/loans": {
      "get": {
        "tags": ["Loans"],
        "description": "Get all loans (Protected)",
        "responses": {
          "200": { "description": "Loans retrieved" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Loans"],
        "description": "Create a loan",
        "parameters": [
          {
            "in": "body",
            "name": "loan",
            "schema": {
              "type": "object",
              "required": ["memberId", "bookId", "dueDate"],
              "properties": {
                "memberId": { "type": "string" },
                "bookId": { "type": "string" },
                "dueDate": { "type": "string" },
                "returnDate": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["borrowed", "returned", "overdue"]
                }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Loan created" }
        }
      }
    },

    "/loans/{id}": {
      "get": {
        "tags": ["Loans"],
        "description": "Get loan by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Loan found" }
        }
      },
      "put": {
        "tags": ["Loans"],
        "description": "Update loan",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "loan",
            "schema": {
              "type": "object",
              "properties": {
                "returnDate": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["borrowed", "returned", "overdue"]
                }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Loan updated" }
        }
      },
      "delete": {
        "tags": ["Loans"],
        "description": "Delete loan",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Loan deleted" }
        }
      }
    }
  }
}